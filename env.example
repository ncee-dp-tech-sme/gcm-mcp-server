# ==================== GCM Server ====================
# Hostname or IP address of the GCM server
GCM_HOST=localhost

# API port for GCM server
GCM_API_PORT=31443

# Keycloak authentication port
GCM_KEYCLOAK_PORT=30443

# ==================== Authentication ====================
# REQUIRED: GCM username for authentication
GCM_USERNAME=your_username_here

# REQUIRED: GCM password for authentication
GCM_PASSWORD=your_password_here

# Client ID for Keycloak authentication
GCM_CLIENT_ID=gcmclient

# REQUIRED: Client secret for Keycloak authentication
GCM_CLIENT_SECRET=your_client_secret_here

# Authentication mode (auto, password, client_credentials)
GCM_AUTH_MODE=auto

# ==================== SSL & Timeouts ====================
# Whether to verify SSL certificates (true/false)
GCM_VERIFY_SSL=false

# Request timeout in seconds
GCM_REQUEST_TIMEOUT=30

# ==================== MCP Server Security ====================
# Path to the key store file (default: /data/keys.json in container)
GCM_MCP_KEY_STORE_PATH=/data/keys.json

# ==================== Logging ====================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
GCM_LOG_LEVEL=INFO

# ==================== REST API Server (Optional) ====================
# HTTP API server host (default: 0.0.0.0)
GCM_API_HOST_HTTP=0.0.0.0

# HTTP API server port (default: 8000)
GCM_API_PORT_HTTP=8000